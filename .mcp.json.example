{
  "mcpServers": {
    "premierpro-mcp": {
      "type": "stdio",
      "command": "/ABSOLUTE/PATH/TO/AdobePremiereProMCP/go-orchestrator/bin/premierpro-mcp",
      "args": [
        "--transport",
        "stdio",
        "--log-level",
        "error"
      ],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}"
      }
    }
  }
}
