# PremierPro MCP Server — Environment Variables

# ─── General ───
LOG_LEVEL=info
ENV=development

# ─── Go Orchestrator ───
MCP_TRANSPORT=stdio
GRPC_PORT=50051
HEALTH_PORT=8080

# ─── Rust Engine ───
RUST_GRPC_PORT=50052
FFMPEG_PATH=/usr/local/bin/ffmpeg
ASSET_CACHE_DIR=./tmp/asset-cache

# ─── Python Intelligence ───
PYTHON_GRPC_PORT=50053
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── TypeScript Bridge ───
TS_BRIDGE_PORT=50054
PREMIERE_PRO_PATH=/Applications/Adobe Premiere Pro 2025/Adobe Premiere Pro 2025.app
CEP_PANEL_MODE=true
FALLBACK_TO_STANDALONE=true

# ─── Slack Bot (cli/src/slack-bot.ts) ───
# Create a Slack app at https://api.slack.com/apps with Socket Mode enabled,
# bot scopes chat:write, channels:history, app_mentions:read, files:read
# (needed to download files uploaded to a thread), reactions:write
# (optional), subscribed to the message.channels event, installed to your
# workspace and invited into one dedicated channel (e.g. #premiere-edits).
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL_ID=C0123456789
#
# SLACK_BOT_TOKEN is also read directly by the Go orchestrator's
# premiere_fetch_slack_attachment tool, to authenticate downloads of files
# uploaded to a Slack thread. It must be present in that process's own
# environment, not just the Slack bot's -- see .mcp.json, which references it
# as ${SLACK_BOT_TOKEN} for Claude Code to resolve from its own environment
# when it launches the premierpro-mcp server.
