# PremierPro MCP Server — Environment Variables

# ─── General ───
LOG_LEVEL=info
ENV=development

# ─── Go Orchestrator ───
MCP_TRANSPORT=stdio
GRPC_PORT=50051
HEALTH_PORT=8080

# ─── Rust Engine ───
RUST_GRPC_PORT=50052
FFMPEG_PATH=/usr/local/bin/ffmpeg
ASSET_CACHE_DIR=./tmp/asset-cache

# ─── Python Intelligence ───
PYTHON_GRPC_PORT=50053
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── TypeScript Bridge ───
TS_BRIDGE_PORT=50054
PREMIERE_PRO_PATH=/Applications/Adobe Premiere Pro 2025/Adobe Premiere Pro 2025.app
CEP_PANEL_MODE=true
FALLBACK_TO_STANDALONE=true

# ─── Slack Bot (cli/src/slack-bot.ts) ───
# Create a Slack app at https://api.slack.com/apps with Socket Mode enabled,
# bot scopes chat:write, channels:history, app_mentions:read,
# reactions:write (optional), subscribed to the message.channels event,
# installed to your workspace and invited into one dedicated channel
# (e.g. #premiere-edits).
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL_ID=C0123456789
